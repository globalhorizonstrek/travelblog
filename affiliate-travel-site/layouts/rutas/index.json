{{- $.Scratch.Add "index" slice -}}
{{- range .Site.RegularPages -}}
  {{- if eq .Section "rutas" -}}
    {{- $.Scratch.Add "index" (dict 
      "title" .Title 
      "url" .Permalink 
      "region" .Params.region
      "pais" .Params.pais
      "dificultad" .Params.dificultad
      "meta_description" .Params.meta_description
    ) -}}
  {{- end -}}
{{- end -}}
{{- $.Scratch.Get "index" | jsonify -}}
